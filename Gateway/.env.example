# ──────────────────────────────────────────────────────────────────────────────
# LLM Gateway V7 — OpenAI-Only Configuration
# Copy this to .env (same directory: Final_Submission/Gateway/.env) and fill in.
# ──────────────────────────────────────────────────────────────────────────────

# ── OpenAI API Key (REQUIRED) ─────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here

# ── Model selection (optional — defaults shown) ───────────────────────────────
# Chat model: gpt-4.1-mini is recommended (fast, cheap, full tool-calling)
OPENAI_MODEL=gpt-4.1-mini

# Embedding model: text-embedding-3-small (1536-dim, very cheap)
# WARNING: Never change this after first index build — it will invalidate
# your FAISS index. Delete state/index.faiss and state/index_ids.json if you do.
EMBED_OPENAI_MODEL=text-embedding-3-small

# ── Gateway port ───────────────────────────────────────────────────────────────
GATEWAY_V7_PORT=8107
