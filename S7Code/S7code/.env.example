# ──────────────────────────────────────────────────────────────────────────────
# S7 Agent — Environment Configuration
# Copy this to .env (same directory: Final_Submission/S7Code/S7code/.env)
# The agent connects to Gateway V7 on port 8107.
# OpenAI key goes in Final_Submission/Gateway/.env — not here.
# ──────────────────────────────────────────────────────────────────────────────

# ── Web search (optional) ─────────────────────────────────────────────────────
# Tavily gives better results but is optional (950 free searches/month).
# DuckDuckGo is used automatically as fallback — no key needed.
TAVILY_API_KEY=tvly-your-key-here
